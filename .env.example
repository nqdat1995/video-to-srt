# OCR Configuration
OCR_CACHE_MAX=4
BATCH_OCR_SIZE=8

# Video Processing Configuration
# DEFAULT_TARGET_FPS: Sampling frames per second (1.0-32.0, default: 4.0)
# Lower values = faster processing but less subtitle accuracy
# Higher values = more frames processed but slower
# Recommended: 2-4 for fast processing, 6-10 for balanced, 15+ for high quality
DEFAULT_TARGET_FPS=10
# Logging Configuration
# LOG_LEVEL: Controls logging verbosity (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: WARNING (minimal debug output from paddleocr and dependencies)
# Use DEBUG only for troubleshooting
LOG_LEVEL=ERROR
# Server Configuration
HOST=0.0.0.0
PORT=8001
DISABLE_AUTO_LOGGING_CONFIG=1

# Suppress PaddlePaddle/PaddleOCR logs
GLOG_minloglevel=2
FLAGS_logtostderr=0
PPOCR_SHOW_LOG=0

# TTS Configuration
TTS_OUTPUT_DIR=./tmp_files/tts_output
TTS_TEMP_DIR=./tmp_files/tts_temp

# Database Configuration
DATABASE_URL=postgresql://postgres:video-to-srt%40123@db.jbjwuyogzcizovozgdjt.supabase.co:5432/postgres

# Storage Configuration
UPLOAD_DIR=./tmp_files/uploads
MAX_VIDEOS_PER_USER=2
MAX_UPLOAD_SIZE_MB=500

# SRT Output Configuration
SRT_OUTPUT_DIR=./tmp_files/srt_output

# SRT Temporary Files Configuration
SRT_TEMP_DIR=./tmp_files/srt_temp