# OCR Configuration
OCR_CACHE_MAX=4
BATCH_OCR_SIZE=8

# Video Processing Configuration
# DEFAULT_TARGET_FPS: Sampling frames per second (1.0-32.0, default: 4.0)
# Lower values = faster processing but less subtitle accuracy
# Higher values = more frames processed but slower
# Recommended: 2-4 for fast processing, 6-10 for balanced, 15+ for high quality
DEFAULT_TARGET_FPS=8
# Logging Configuration
# LOG_LEVEL: Controls logging verbosity (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: WARNING (minimal debug output from paddleocr and dependencies)
# Use DEBUG only for troubleshooting
LOG_LEVEL=ERROR
# Server Configuration
HOST=0.0.0.0
PORT=8001
DISABLE_AUTO_LOGGING_CONFIG=1

# Suppress PaddlePaddle/PaddleOCR logs
GLOG_minloglevel=2
FLAGS_logtostderr=0
PPOCR_SHOW_LOG=0